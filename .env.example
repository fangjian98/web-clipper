# ===========================================
# API 配置
# ===========================================

# 解析 API 地址
# 支持格式：
# 1. Jina AI (默认): https://r.jina.ai
# 2. 自定义 API: https://your-api.com
VITE_API_BASE_URL=https://r.jina.ai

# API Key (可选)
VITE_API_KEY=

# ===========================================
# Supabase 配置 (可选)
# ===========================================

# 您的 Supabase 项目 URL
VITE_SUPABASE_URL=https://your-project.supabase.co

# 您的 Supabase anon key
VITE_SUPABASE_ANON_KEY=your-anon-key
